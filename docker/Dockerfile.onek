# Multi-stage build for the onek CLI
FROM golang:1.26-alpine AS builder

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /onek ./cmd/onek

FROM alpine:latest

COPY --from=builder /onek /usr/local/bin/onek
RUN chmod +x /usr/local/bin/onek

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/onek"]
